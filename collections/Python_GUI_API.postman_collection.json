		{
			"name": "weather score - defaults",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response contains required top-level fields\", function () {",
							"    const jsonData = pm.response.json();",
							"",
							"    pm.expect(jsonData).to.have.property(\"results\");",
							"    pm.expect(jsonData).to.have.property(\"threshold\");",
							"    pm.expect(jsonData).to.have.property(\"penalize_rain\");",
							"    pm.expect(jsonData).to.have.property(\"start_day\");",
							"});",
							"",
							"pm.test(\"results is an array\", function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.results).to.be.an(\"array\");",
							"});",
							"",
							"pm.test(\"Default threshold is 20\", function () {",
							"    pm.expect(pm.response.json().threshold).to.eql(20);",
							"});",
							"",
							"pm.test(\"Default penalize_rain is true\", function () {",
							"    pm.expect(pm.response.json().penalize_rain).to.eql(true);",
							"});",
							"",
							"pm.test(\"Default start_day is 0\", function () {",
							"    pm.expect(pm.response.json().start_day).to.eql(0);",
							"});",
							"",
							"pm.test(\"Each result has required fields\", function () {",
							"    const results = pm.response.json().results;",
							"    results.forEach(function (record) {",
							"        pm.expect(record).to.have.property(\"key\");",
							"        pm.expect(record).to.have.property(\"name\");",
							"        pm.expect(record).to.have.property(\"latitude\");",
							"        pm.expect(record).to.have.property(\"longitude\");",
							"        pm.expect(record).to.have.property(\"timezone\");",
							"        pm.expect(record).to.have.property(\"score\");",
							"    });",
							"});",
							"",
							"pm.test(\"Results are sorted by score descending\", function () {",
							"    const scores = pm.response.json().results.map(r => r.score);",
							"    for (let i = 0; i < scores.length - 1; i++) {",
							"        pm.expect(scores[i]).to.be.at.least(scores[i + 1]);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{}"
