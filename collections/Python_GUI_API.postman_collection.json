		{
			"name": "weather info - Poland",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response contains required top-level fields\", function () {",
							"    const jsonData = pm.response.json();",
							"",
							"    pm.expect(jsonData).to.have.property(\"hourly\");",
							"    pm.expect(jsonData).to.have.property(\"daily\");",
							"    pm.expect(jsonData).to.have.property(\"hourly_rows\");",
							"    pm.expect(jsonData).to.have.property(\"daily_rows\");",
							"});",
							"",
							"pm.test(\"Hourly and daily are arrays\", function () {",
							"    const jsonData = pm.response.json();",
							"",
							"    pm.expect(jsonData.hourly).to.be.an(\"array\");",
							"    pm.expect(jsonData.daily).to.be.an(\"array\");",
							"});",
							"",
							"pm.test(\"Row counters match array lengths\", function () {",
							"    const jsonData = pm.response.json();",
							"",
							"    pm.expect(jsonData.hourly_rows).to.eql(jsonData.hourly.length);",
							"    pm.expect(jsonData.daily_rows).to.eql(jsonData.daily.length);",
							"});",
							"",
							"pm.test(\"Forecast days are returned\", function () {",
							"    const jsonData = pm.response.json();",
							"",
							"    pm.expect(jsonData.daily.length).to.eql(3);",
							"    pm.expect(jsonData.daily_rows).to.eql(3);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
